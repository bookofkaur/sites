{
  "ci": {
    "collect": {
      "staticDistDir": ".",
      "url": [
        "http://localhost/index.html",
        "http://localhost/sole-ops/index.html",
        "http://localhost/peach-state-savings/index.html",
        "http://localhost/college-confused/index.html",
        "http://localhost/college-confused/blog.html"
      ],
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop"
      }
    },
    "assert": {
      "assertions": {
        "categories:accessibility": ["error", { "minScore": 0.9 }],
        "categories:performance": ["warn", { "minScore": 0.9 }],
        "categories:best-practices": ["warn", { "minScore": 0.9 }],
        "categories:seo": ["warn", { "minScore": 0.9 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
